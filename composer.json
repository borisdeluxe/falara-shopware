{
    "name": "falara/shopware-translation-manager",
    "description": "Falara Translation Manager for Shopware 6 — AI-powered translations with multi-provider support",
    "version": "1.0.0",
    "type": "shopware-platform-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Falara GmbH"
        }
    ],
    "require": {
        "php": ">=8.2",
        "shopware/core": "~6.7",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Falara\\TranslationManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Falara\\TranslationManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "shopware-plugin-class": "Falara\\TranslationManager\\FalaraTranslationManager",
        "label": {
            "de-DE": "Falara Translation Manager",
            "en-GB": "Falara Translation Manager"
        },
        "description": {
            "de-DE": "KI-gestützte Übersetzungen für Ihren Shopware Shop mit Multi-Provider Support (DeepL, Claude, Gemini, ChatGPT)",
            "en-GB": "AI-powered translations for your Shopware store with multi-provider support (DeepL, Claude, Gemini, ChatGPT)"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
